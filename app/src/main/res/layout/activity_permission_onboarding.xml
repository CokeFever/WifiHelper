<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    android:padding="32dp">

    <!-- App icon -->
    <ImageView
        android:id="@+id/onboarding_app_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@mipmap/ic_launcher"
        android:contentDescription="@string/app_name"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/onboarding_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/onboarding_title"
        android:textColor="@color/on_background"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/onboarding_app_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Step indicator -->
    <TextView
        android:id="@+id/onboarding_step_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/primary"
        android:textSize="14sp"
        android:layout_marginTop="16dp"
        tools:text="步驟 1 / 4"
        app:layout_constraintTop_toBottomOf="@id/onboarding_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/onboarding_progress"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:progressTint="@color/primary"
        android:progressBackgroundTint="@color/surface"
        app:layout_constraintTop_toBottomOf="@id/onboarding_step_indicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Step description -->
    <TextView
        android:id="@+id/onboarding_step_description"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:textColor="@color/on_background"
        android:textSize="18sp"
        android:lineSpacingExtra="6dp"
        android:gravity="center"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp"
        tools:text="WiFi 掃描需要精確位置權限，以便偵測周圍的 WiFi 網路。"
        app:layout_constraintTop_toBottomOf="@id/onboarding_progress"
        app:layout_constraintBottom_toTopOf="@id/onboarding_grant_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Grant permission button (min 72dp for car use) -->
    <Button
        android:id="@+id/onboarding_grant_button"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:text="@string/onboarding_grant_permission"
        android:textSize="18sp"
        android:textColor="@color/on_primary"
        android:backgroundTint="@color/primary"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/onboarding_skip_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Skip button (only visible for optional permissions) -->
    <TextView
        android:id="@+id/onboarding_skip_button"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:gravity="center"
        android:text="@string/onboarding_skip"
        android:textColor="@color/primary"
        android:textSize="16sp"
        android:visibility="gone"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
