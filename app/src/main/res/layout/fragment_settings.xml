<?xml version="1.0" encoding="utf-8"?>
<!-- Settings fragment layout -->
<!-- Requirements: 4.2 (auto-start switch), 6.3 (interactive elements min 48dp),
     6.6 (text min 16sp) -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Centered content group -->
    <LinearLayout
        android:id="@+id/settings_content"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/footer_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.45">

        <!-- Auto Start Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/auto_start_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/auto_start_label"
                android:textColor="@color/on_background"
                android:textSize="20sp"
                android:textStyle="bold" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/auto_start_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="48dp"
                android:minHeight="48dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/auto_start_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/auto_start_description"
            android:textColor="@color/on_background"
            android:textSize="16sp"
            android:alpha="0.7" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:background="@color/on_background"
            android:alpha="0.2" />

        <!-- Signal Threshold Section -->
        <TextView
            android:id="@+id/signal_threshold_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/signal_threshold_label"
            android:textColor="@color/on_background"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/signal_threshold_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/signal_threshold_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="48dp"
            android:max="70"
            android:progress="30"
            android:thumbTint="@color/primary"
            android:progressTint="@color/primary"
            android:progressBackgroundTint="@color/on_background" />

        <TextView
            android:id="@+id/signal_range_labels"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:textColor="@color/on_background"
            android:textSize="14sp"
            android:alpha="0.5" />

        <TextView
            android:id="@+id/signal_threshold_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/signal_threshold_description"
            android:textColor="@color/on_background"
            android:textSize="16sp"
            android:alpha="0.7" />

    </LinearLayout>

    <!-- Footer: version + website -->
    <TextView
        android:id="@+id/footer_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:textColor="@color/on_background"
        android:textSize="12sp"
        android:alpha="0.5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
