<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Spacer to push content toward center when there's room -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Auto Start Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/auto_start_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_start_label"
                    android:textColor="@color/on_background"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/auto_start_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/auto_start_description"
                    android:textColor="@color/on_background"
                    android:textSize="14sp"
                    android:alpha="0.7" />

            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/auto_start_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="48dp"
                android:minHeight="48dp" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="@color/on_background"
            android:alpha="0.2" />

        <!-- Signal Threshold Section -->
        <TextView
            android:id="@+id/signal_threshold_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/signal_threshold_label"
            android:textColor="@color/on_background"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/signal_threshold_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="@color/primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/signal_threshold_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"
            android:max="70"
            android:progress="30"
            android:thumbTint="@color/primary"
            android:progressTint="@color/primary"
            android:progressBackgroundTint="@color/on_background" />

        <TextView
            android:id="@+id/signal_range_labels"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/on_background"
            android:textSize="13sp"
            android:alpha="0.5" />

        <TextView
            android:id="@+id/signal_threshold_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/signal_threshold_description"
            android:textColor="@color/on_background"
            android:textSize="14sp"
            android:alpha="0.7" />

        <!-- Spacer to push footer down when there's room -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Footer section: send log + version -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="@color/on_background"
            android:alpha="0.1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/send_log_button"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:text="@string/send_log_button"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/footer_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:textColor="@color/on_background"
            android:textSize="12sp"
            android:alpha="0.5" />

    </LinearLayout>

</ScrollView>
