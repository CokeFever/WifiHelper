<?xml version="1.0" encoding="utf-8"?>
<!-- Settings fragment layout -->
<!-- Requirements: 4.2 (auto-start switch), 6.3 (interactive elements min 48dp),
     6.6 (text min 16sp) -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <!-- Auto Start Section -->
    <TextView
        android:id="@+id/auto_start_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/auto_start_label"
        android:textColor="@color/on_background"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/auto_start_switch" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/auto_start_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="48dp"
        android:minHeight="48dp"
        app:layout_constraintTop_toTopOf="@id/auto_start_label"
        app:layout_constraintBottom_toBottomOf="@id/auto_start_label"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/auto_start_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/auto_start_description"
        android:textColor="@color/on_background"
        android:textSize="16sp"
        android:alpha="0.7"
        app:layout_constraintTop_toBottomOf="@id/auto_start_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Divider -->
    <View
        android:id="@+id/divider_settings"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="@color/on_background"
        android:alpha="0.2"
        app:layout_constraintTop_toBottomOf="@id/auto_start_description"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Signal Threshold Section -->
    <TextView
        android:id="@+id/signal_threshold_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/signal_threshold_label"
        android:textColor="@color/on_background"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/divider_settings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/signal_threshold_value"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/primary"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/signal_threshold_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <SeekBar
        android:id="@+id/signal_threshold_seekbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:minHeight="48dp"
        android:max="70"
        android:progress="30"
        android:thumbTint="@color/primary"
        android:progressTint="@color/primary"
        android:progressBackgroundTint="@color/on_background"
        app:layout_constraintTop_toBottomOf="@id/signal_threshold_value"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/signal_threshold_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/signal_threshold_description"
        android:textColor="@color/on_background"
        android:textSize="16sp"
        android:alpha="0.7"
        app:layout_constraintTop_toBottomOf="@id/signal_threshold_seekbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
